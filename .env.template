# =============================================================================
# TEMPLATE DE CONFIGURATION - REMPLISSEZ VOS VRAIES VALEURS
# =============================================================================

# --- BASE DE DONNÉES ---
# Pour débuter, utilisez SQLite (pas besoin d'installer PostgreSQL)
DATABASE_URL=sqlite:///./flight_deals.db

# --- AMADEUS API (OBLIGATOIRE) ---
# 1. Allez sur https://developers.amadeus.com
# 2. Créez un compte GRATUIT
# 3. Créez une application Self-Service
# 4. Copiez votre API Key et Secret ci-dessous
AMADEUS_API_KEY=REMPLACEZ_PAR_VOTRE_CLE
AMADEUS_API_SECRET=REMPLACEZ_PAR_VOTRE_SECRET
AMADEUS_API_URL=https://test.api.amadeus.com

# --- DISCORD WEBHOOK (OBLIGATOIRE) ---
# 1. Sur Discord, clic droit sur un canal > Modifier le canal
# 2. Intégrations > Webhooks > Créer un webhook
# 3. Copiez l'URL du webhook ci-dessous
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REMPLACEZ_PAR_VOTRE_URL

# --- PARAMÈTRES DE RECHERCHE ---
DEPARTURE_AIRPORT=GVA
DESTINATIONS=NRT,HND,PVG,HAN,BKK,KUL,CGK
SEARCH_WINDOW_DAYS=180
MIN_STAY_DAYS=7
MAX_STAY_DAYS=14
MAX_STOPS=1
CURRENCY=EUR
ADULTS=1

# --- SCORING ---
SCORE_THRESHOLD=70

# --- SCHEDULER ---
SEARCH_INTERVAL_HOURS=6

# --- APPLICATION ---
PORT=8000
DEBUG=True
