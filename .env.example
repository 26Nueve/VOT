# ============================================
# CONFIGURATION DE L'APPLICATION
# ============================================
# Copier ce fichier en ".env" et remplir vos vraies valeurs

# --- API AMADEUS ---
# Créer un compte sur : https://developers.amadeus.com
# Aller dans "My Self-Service Workspace" → Créer une app → Copier les clés
AMADEUS_API_KEY=your_api_key_here
AMADEUS_API_SECRET=your_api_secret_here

# --- DISCORD WEBHOOK ---
# Dans Discord : Paramètres du salon → Intégrations → Webhooks → Nouveau Webhook
# Copier l'URL du webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# --- BASE DE DONNÉES ---
# Pour SQLite (développement local) :
DATABASE_URL=sqlite:///./flight_deals.db

# Pour PostgreSQL (production - décommenter et utiliser celle-ci) :
# DATABASE_URL=postgresql://user:password@localhost:5432/flight_deals

# --- PARAMÈTRES DE RECHERCHE ---
# Aéroport de départ (code IATA)
DEPARTURE_AIRPORT=GVA

# Destinations (codes IATA séparés par des virgules)
# TYO=Tokyo, PEK=Pékin, HAN=Hanoi, BKK=Bangkok, KUL=Kuala Lumpur, CGK=Jakarta
DESTINATIONS=TYO,PEK,HAN,BKK,KUL,CGK

# Durée min/max du séjour (en jours)
MIN_TRIP_DURATION=7
MAX_TRIP_DURATION=14

# Fenêtre de recherche (en mois)
SEARCH_WINDOW_MONTHS=6

# Nombre maximum d'escales
MAX_STOPOVERS=1

# --- SCORING ---
# Seuil minimum pour notifier (0-100)
MIN_SCORE_THRESHOLD=70

# --- SCHEDULER ---
# Fréquence de recherche automatique (en heures)
SEARCH_FREQUENCY_HOURS=6

# --- APPLICATION ---
# Port de l'application web
APP_PORT=8000

# Mode debug (True pour développement, False pour production)
DEBUG=True
